<%- include('../partials/layout-start') %>

<section class="login-shell">
  <article class="login-card">
    <div class="login-mark">
      <div class="crest large">
        <span class="crest-m">M</span>
        <span class="crest-ribbon">MAROOCHYDORE</span>
      </div>

      <div>
        <h1>Create a new password</h1>
        <p>Enter and confirm your new password.</p>
      </div>
    </div>

    <% if (error) { %>
      <div class="form-alert danger"><%= error %></div>
    <% } %>

    <form action="/reset-password/<%= token %>" method="post" class="login-form">
      <label>
        <span>New password</span>
        <input
          name="password"
          type="password"
          placeholder="Enter new password"
          autocomplete="new-password"
          required
          minlength="8"
        />
      </label>

      <label>
        <span>Confirm new password</span>
        <input
          name="confirmPassword"
          type="password"
          placeholder="Confirm new password"
          autocomplete="new-password"
          required
          minlength="8"
        />
      </label>

      <button type="submit" class="btn btn-primary full-width">
        Update Password
      </button>
    </form>

    <div class="login-footer-actions">
      <a href="/login">Back to sign in</a>
    </div>

    <div class="login-note">
      <strong>Password guidance</strong>
      <p>
        Use at least 8 characters. A longer password with words, numbers and symbols is stronger.
      </p>
    </div>
  </article>
</section>

<%- include('../partials/layout-end') %>