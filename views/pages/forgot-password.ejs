<%- include('../partials/layout-start') %>

<section class="login-shell">
  <article class="login-card">
    <div class="login-mark">
      <div class="crest large">
        <span class="crest-m">M</span>
        <span class="crest-ribbon">MAROOCHYDORE</span>
      </div>

      <div>
        <h1>Reset your password</h1>
        <p>Enter your first name and school email.</p>
      </div>
    </div>

    <% if (error) { %>
      <div class="form-alert danger"><%= error %></div>
    <% } %>

    <% if (success) { %>
      <div class="form-alert success"><%= success %></div>
    <% } %>

    <form action="/forgot-password" method="post" class="login-form">
      <label>
        <span>First name</span>
        <input
          name="firstName"
          type="text"
          placeholder="Enter your first name"
          autocomplete="given-name"
          required
        />
      </label>

      <label>
        <span>Email</span>
        <input
          name="email"
          type="email"
          placeholder="Enter your school email"
          autocomplete="email"
          required
        />
      </label>

      <button type="submit" class="btn btn-primary full-width">
        Send Reset Password Email
      </button>
    </form>

    <div class="login-footer-actions">
      <a href="/login">Back to sign in</a>
    </div>

    <div class="login-note">
      <strong>What happens next?</strong>
      <p>
        If the details match a staff account, a reset password email will be sent to the registered address.
      </p>
    </div>
  </article>
</section>

<%- include('../partials/layout-end') %>