<%- include('../partials/layout-start') %>
<section class="page-head"><h1>Lab Damage Reports</h1><div class="actions"><button class="btn btn-primary">＋ New Damage Report</button><button class="btn btn-light">⇩ Export ˅</button></div></section>
<section class="damage-layout">
  <div class="card lab-layout-card"><div class="lab-head"><h3>Lab Layout</h3><button class="select-btn">▣ Science Lab 2 ˅</button></div><div class="floorplan"><span class="door"></span><span class="wall-feature"></span><% for (let i = 1; i <= 24; i++) { %><button class="pc-tile <%= i === 5 ? 'maintenance' : i === 19 ? 'damaged' : '' %>"><span><%= i === 5 || i === 19 ? '△' : '▭' %></span><b><%= String(i).padStart(2, '0') %></b></button><% } %></div><div class="lab-legend"><span><b class="dot blue-dot"></b>Available</span><span><b class="dot red-dot"></b>Damaged</span><span><b class="dot green-dot"></b>In Use</span><span><b class="dot orange-dot"></b>Maintenance</span><div class="zoom-controls"><button>⌕</button><span>100%</span><button>⌕</button></div></div></div>
  <aside class="card damage-form"><h3>Damage Report Details</h3><label>Lab<select><option>Science Lab 2</option></select></label><label>Computer Number<select><option>05</option></select></label><label>Damage Type<select><option>Broken Monitor</option></select></label><label>Severity<select><option>● Moderate</option></select></label><label>Student Involved (if known)<select><option>John Smith (Year 10)</option></select></label><label>Photo Evidence<div class="photo-row"><div class="photo-thumb">✕</div><button class="btn btn-outline">Upload Photo</button><small>JPG, PNG up to 5MB</small></div></label><label class="toggle-row">Follow-up Required <span class="toggle on"></span> Yes</label><label>Status <span class="tag orange-tag">Reported ›</span></label><label>Notes<textarea>Cracked screen on left side. Occurred during Science practical.</textarea></label></aside>
</section>
<section class="card table-card recent-damage"><div class="card-head"><h3>Recent Damage Reports</h3><a>View all reports ›</a></div><table class="data-table"><thead><tr><th>Date Reported</th><th>Lab</th><th>Computer #</th><th>Damage Type</th><th>Severity</th><th>Student Involved</th><th>Status</th><th>Reported By</th><th>Actions</th></tr></thead><tbody><% damageReports.forEach(r => { %><tr><td><%= r.date %></td><td><%= r.lab %></td><td><%= r.computer %></td><td><%= r.type %></td><td><span class="tag <%= r.severity %>"><%= r.severity %></span></td><td><%= r.student %></td><td><span class="status <%= r.status %>"><%= r.status %></span></td><td><%= r.reportedBy %></td><td><button class="icon-btn">⋯</button></td></tr><% }) %></tbody></table></section>
<%- include('../partials/layout-end') %>
